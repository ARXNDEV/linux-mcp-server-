{
  "name": "@arxndev/container-mcp",
  "version": "0.1.0",
  "description": "MCP server for Apple container — manage Linux containers on macOS via AI",
  "type": "module",
  "bin": {
    "container-mcp": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "apple-container",
    "containers",
    "macos",
    "ai-tools",
    "claude",
    "model-context-protocol",
    "linux-containers",
    "apple-silicon"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "execa": "^9.5.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "@vitest/coverage-v8": "^3.2.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
